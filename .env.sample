# Environment Variables Sample
# Copy this file to .env and fill in the values for your local development

# Required: Database connection URL
# For local development with SQLite (default):
# DATABASE_URL=sqlite:./axum_kickoff.db
# For in-memory SQLite (for testing):
# DATABASE_URL=sqlite::memory:
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/axum_kickoff
DATABASE_URL=sqlite:./axum_kickoff.db

# Required: Session key for signing and encrypting cookies
# Generate a secure random key. In production, this should be a long, random string.
SESSION_KEY=use-a-session-key-with-64-bytes-or-more-here-and-store-it-securely

# Required: GitHub OAuth credentials
# Create an OAuth app at https://github.com/settings/developers
GH_CLIENT_ID=your_github_client_id
GH_CLIENT_SECRET=your_github_client_secret

# Optional: GitHub OAuth redirect URI (defaults to http://localhost:8888/api/v1/auth/github/callback)
# GH_REDIRECT_URI=http://localhost:8888/api/v1/auth/github/callback

# Required: Comma-separated list of allowed CORS origins
# For local development, include your frontend URL(s)
WEB_ALLOWED_ORIGINS=http://localhost:8888,http://127.0.0.1:8888

# Optional: Port to listen on (defaults to 8888)
PORT=8888

# Optional: Domain name of the application (defaults to "localhost")
DOMAIN_NAME=localhost

# Optional: Trusted proxy IPs/CIDR ranges for X-Forwarded-For header
# Format: Comma-separated list in CIDR notation (e.g., "127.0.0.1/32,::1/128,10.0.0.0/8")
# Defaults to "127.0.0.1/32,::1/128" (localhost) for safety
# TRUSTED_PROXIES=127.0.0.1/32,::1/128

# Optional: Maximum number of blocking threads (leave unset for default)
# SERVER_THREADS=4

# Optional: Set to any value to indicate running in Docker
# DEV_DOCKER=1

# Optional: Set to any value to indicate running on Heroku
# HEROKU=1

# Storage Configuration
# Optional: Path for local filesystem storage (defaults to "./local_uploads")
# STORAGE_PATH=./local_uploads

# Optional: CDN prefix for generating public URLs (e.g., "cdn.example.com")
# CDN_PREFIX=

# Security: Rate Limiting Configuration
# Format: RATE_LIMITER_{ACTION}_RATE_SECONDS and RATE_LIMITER_{ACTION}_BURST
# Actions: API_REQUEST, LOGIN_ATTEMPT, PASSWORD_RESET, FILE_UPLOAD, FORM_SUBMISSION
# RATE_LIMITER_API_REQUEST_RATE_SECONDS=1
# RATE_LIMITER_API_REQUEST_BURST=10
# RATE_LIMITER_LOGIN_ATTEMPT_RATE_SECONDS=5
# RATE_LIMITER_LOGIN_ATTEMPT_BURST=5
# RATE_LIMITER_PASSWORD_RESET_RATE_SECONDS=60
# RATE_LIMITER_PASSWORD_RESET_BURST=3
# RATE_LIMITER_FILE_UPLOAD_RATE_SECONDS=10
# RATE_LIMITER_FILE_UPLOAD_BURST=5
# RATE_LIMITER_FORM_SUBMISSION_RATE_SECONDS=30
# RATE_LIMITER_FORM_SUBMISSION_BURST=10

# Security: Blocked IP addresses (comma-separated)
# BLOCKED_IPS=192.168.1.100,10.0.0.50

# Security: Blocked route patterns (comma-separated)
# BLOCKED_ROUTES=/api/admin,/api/internal

# Security: Blocked traffic by headers
# Format: HeaderName=ENV_VAR_NAME,HeaderName2=ENV_VAR_NAME2
# Each ENV_VAR should contain comma-separated values to block
# Values starting and ending with / are treated as regex patterns
# BLOCKED_TRAFFIC=User-Agent=BLOCKED_UAS
# BLOCKED_UAS=/curl\/[\d]+\.[\d]+\.[\d]+/,bad-bot

# Security: Security Headers Configuration
# Enable HSTS (HTTPS only - requires HTTPS to be effective)
# SECURITY_HSTS_ENABLED=false

# HSTS max-age in seconds (default: 31536000 = 1 year)
# SECURITY_HSTS_MAX_AGE=31536000

# HSTS includeSubDomains directive
# SECURITY_HSTS_INCLUDE_SUBDOMAINS=true

# HSTS preload directive (for inclusion in browser preload lists)
# SECURITY_HSTS_PRELOAD=false

# Content-Security-Policy mode: strict, permissive, or custom:CSP_STRING
# SECURITY_CSP_MODE=strict

# X-Frame-Options: deny, sameorigin, or allow-from:URL
# SECURITY_FRAME_OPTIONS=deny

# Custom frame ancestors for CSP (overrides frame-ancestors directive)
# SECURITY_FRAME_ANCESTORS=https://trusted-domain.com

# Referrer-Policy: no-referrer, no-referrer-when-downgrade, unsafe-url,
# strict-origin-when-cross-origin, same-origin, strict-origin, origin-when-cross-origin
# SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin

# Permissions-Policy: restrictive, permissive, or custom:POLICY_STRING
# SECURITY_PERMISSIONS_POLICY=restrictive
